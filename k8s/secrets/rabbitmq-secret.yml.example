---
# Secret for RabbitMQ in the data namespace (used by the StatefulSet)
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
  namespace: data
type: Opaque
stringData:
  username: "admin"
  password: "YOUR_RABBITMQ_PASSWORD_HERE"
  erlang-cookie: "YOUR_ERLANG_COOKIE_HERE"
---
# Mirror secret in saferoute namespace (used by SOS, notification, feedback services)
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-secret
  namespace: saferoute
type: Opaque
stringData:
  username: "admin"
  password: "YOUR_RABBITMQ_PASSWORD_HERE"
